{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cortex-v2/signals",
  "title": "Signal Schema",
  "description": "Core signal data structure for DEEVO Cortex",
  
  "definitions": {
    "SignalSource": {
      "type": "string",
      "enum": ["MACRO", "MARKET", "INSURANCE", "FRAUD", "CLAIMS", "REGULATORY", "GEOPOLITICAL"]
    },
    
    "SignalSeverity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    
    "SignalTrend": {
      "type": "string",
      "enum": ["RISING", "STABLE", "FALLING", "VOLATILE"]
    },
    
    "GCCRegion": {
      "type": "string",
      "enum": ["UAE", "KSA", "QATAR", "KUWAIT", "BAHRAIN", "OMAN", "GCC_WIDE"]
    },
    
    "Signal": {
      "type": "object",
      "required": ["id", "name", "source", "value", "timestamp"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^SIG-[A-Z]{3}-[0-9]{6}$"
        },
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 100
        },
        "source": {
          "$ref": "#/definitions/SignalSource"
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "region": {
          "$ref": "#/definitions/GCCRegion"
        },
        "severity": {
          "$ref": "#/definitions/SignalSeverity"
        },
        "trend": {
          "$ref": "#/definitions/SignalTrend"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source_url": { "type": "string", "format": "uri" },
            "last_updated": { "type": "string", "format": "date-time" },
            "data_quality": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    
    "SignalGroup": {
      "type": "object",
      "required": ["group_id", "name", "signals"],
      "properties": {
        "group_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "signals": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Signal"
          }
        },
        "aggregate_severity": {
          "$ref": "#/definitions/SignalSeverity"
        }
      }
    }
  },
  
  "type": "object",
  "properties": {
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Signal"
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SignalGroup"
      }
    },
    "snapshot_timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
