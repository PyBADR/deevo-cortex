{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cortex-v2/decision",
  "title": "Decision Schema",
  "description": "Decision output and recommendation structures",
  
  "definitions": {
    "DecisionType": {
      "type": "string",
      "enum": ["APPROVE", "REJECT", "REVIEW", "ESCALATE", "DEFER", "CONDITIONAL_APPROVE"]
    },
    
    "ConfidenceLevel": {
      "type": "string",
      "enum": ["VERY_LOW", "LOW", "MEDIUM", "HIGH", "VERY_HIGH"]
    },
    
    "RiskLevel": {
      "type": "string",
      "enum": ["MINIMAL", "LOW", "MODERATE", "HIGH", "SEVERE", "CRITICAL"]
    },
    
    "EvidenceItem": {
      "type": "object",
      "required": ["source", "description", "weight"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Signal ID, Rule ID, or Node ID"
        },
        "description": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "direction": {
          "type": "string",
          "enum": ["SUPPORTS", "OPPOSES", "NEUTRAL"]
        }
      }
    },
    
    "Recommendation": {
      "type": "object",
      "required": ["action", "rationale"],
      "properties": {
        "action": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["IMMEDIATE", "HIGH", "MEDIUM", "LOW"]
        },
        "owner": {
          "type": "string"
        },
        "deadline": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    
    "Decision": {
      "type": "object",
      "required": ["decision_id", "type", "risk_score", "confidence", "timestamp"],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-[0-9]{8}-[A-Z]{4}$"
        },
        "type": {
          "$ref": "#/definitions/DecisionType"
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_level": {
          "$ref": "#/definitions/RiskLevel"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_level": {
          "$ref": "#/definitions/ConfidenceLevel"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "context": {
          "type": "object",
          "properties": {
            "domain": { "type": "string" },
            "region": { "type": "string" },
            "entity_id": { "type": "string" },
            "scenario_id": { "type": "string" }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EvidenceItem"
          }
        },
        "rules_triggered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Recommendation"
          }
        },
        "executive_summary": {
          "type": "string",
          "maxLength": 500
        },
        "detailed_analysis": {
          "type": "string"
        },
        "audit_trail": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "input": { "type": "object" },
              "output": { "type": "object" }
            }
          }
        }
      }
    }
  },
  
  "type": "object",
  "$ref": "#/definitions/Decision"
}
