{
  "canonical_graph_file": "data/graph.json",
  "engine_file": "core/graph_engine.py",
  "adapter_file": "core/graph_adapter.py",
  "functions": [
    {
      "name": "get_graph_state",
      "signature": "get_graph_state(signals?: dict, country_id?: str, lob?: str) -> dict",
